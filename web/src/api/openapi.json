        "properties": {
          "op": {
            "type": "string",
            "const": "update_text",
            "title": "Op"
          },
          "uid": {
            "type": "string",
            "title": "Uid"
          },
          "text": {
            "type": "string",
            "title": "Text"
          }
        },
        "type": "object",
        "required": [
          "op",
          "uid",
          "text"

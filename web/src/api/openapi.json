                  "delete": "#/components/schemas/DeleteOp",
                  "move": "#/components/schemas/MoveOp",
                  "set_collapsed": "#/components/schemas/SetCollapsedOp",
                  "update_text": "#/components/schemas/UpdateTextOp"
